# Backend-only env vars for local development (without Docker).
# Copy to backend/.env — never commit .env.

DATABASE_URL=postgresql+asyncpg://iot_user:iotpassword@localhost:5432/iot_monitor

JWT_SECRET_KEY=dev-secret-change-in-production

MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

SEED_SUPERUSER_EMAIL=admin@coop.local
SEED_SUPERUSER_USERNAME=admin
SEED_SUPERUSER_PASSWORD=Admin1234!

# ── SMTP for OTP emails ────────────────────────────────────────────────────
# Local development with MailHog (no real email sent):
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_TLS=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER_NAME=CoopIoT Monitor
SMTP_SENDER_ADDR=

# Gmail (requires App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_TLS=true
